# Copy to apps/web/.env.local and fill in values.
#   cp .env.example apps/web/.env.local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Adapter (ADR-0020 / ADR-0021). Server-only — never expose keys to the client.
# Providers: null | anthropic | gemini
AI_PROVIDER=null

# Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Optional override (default: claude-3-5-haiku-20241022)
# ANTHROPIC_MODEL=

# Gemini (when AI_PROVIDER=gemini)
GEMINI_API_KEY=
# Optional override (default: gemini-3.6-flash)
# GEMINI_MODEL=gemini-3.6-flash

# Shared Runtime timeout (ms) — AbortSignal + Gemini httpOptions when set
# AI_ADAPTER_TIMEOUT_MS=30000
